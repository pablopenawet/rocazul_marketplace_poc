{
  "PreToolUse": [
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/bash-guard.py",
          "timeout": 5,
          "statusMessage": "Static safety check..."
        },
        {
          "type": "command",
          "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/bash-guard-llm.py",
          "timeout": 35,
          "statusMessage": "LLM analyzing command..."
        }
      ]
    }
  ]
}
